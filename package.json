{
  "name": "ificam",
  "version": "21.6.32",
  "description": "iFicam by @Ungyani - turn a phone into a wireless HD webcam and recorder for Windows.",
  "main": "out/main/index.js",
  "author": "Ungyani",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "prepare:assets": "node scripts/prepare-build-assets.mjs",
    "prepare:release-assets": "node scripts/prepare-release-assets.mjs",
    "build": "npm run prepare:assets && tsc --noEmit && electron-vite build",
    "build:win": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win --x64",
    "build:all": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win --x64 --ia32",
    "release": "npm version patch && set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run build:all -- --publish never && npm run prepare:release-assets"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.3.24",
    "lucide-react": "^0.468.0",
    "png-to-ico": "^3.0.1",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^2.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.39",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.6",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "app.ificam.desktop",
    "productName": "iFicam",
    "copyright": "Copyright 2026 Ungyani",
    "buildVersion": "21.06.26.1",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out/phone",
        "to": "phone"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "releaseType": "release",
        "owner": "dhruvdroid717",
        "repo": "ificam"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "signExecutable": false
    },
    "nsis": {
      "artifactName": "iFicam-Setup-${version}-${arch}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "iFicam",
      "menuCategory": "Ungyani",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "license": "build/EULA.txt",
      "include": "build/installer/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "guid": "52073737-a50c-567f-a814-83095e7e9cd8",
      "runAfterFinish": true,
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp",
      "installerHeader": "build/installer-header.bmp"
    },
    "afterPack": "scripts/after-pack.cjs"
  }
}
